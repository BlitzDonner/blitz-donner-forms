{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "bdfrms/field-radio",
    "version": "2.0.0",
    "title": "Radio-Auswahl",
    "category": "bdfrms-fields",
    "icon": {
        "src": "marker"
    },
    "description": "Eine Option aus mehreren wählen.",
    "textdomain": "blitz-donner-forms",
    "attributes": {
        "label": {
            "type": "string",
            "default": "Auswahl"
        },
        "name": {
            "type": "string",
            "default": ""
        },
        "nameClientId": {
            "type": "string",
            "default": ""
        },
        "options": {
            "type": "string",
            "default": "Option A\nOption B\nOption C"
        },
        "required": {
            "type": "boolean",
            "default": false
        },
        "optionsLayout": {
            "type": "string",
            "default": "column"
        },
        "sensitive": {
            "type": "boolean",
            "default": false
        },
        "helpText": {
            "type": "string",
            "default": ""
        },
        "colorLabel": {
            "type": "string",
            "default": ""
        },
        "colorText": {
            "type": "string",
            "default": ""
        },
        "colorPlaceholder": {
            "type": "string",
            "default": ""
        },
        "colorFieldBg": {
            "type": "string",
            "default": ""
        },
        "colorBorder": {
            "type": "string",
            "default": ""
        },
        "colorFocus": {
            "type": "string",
            "default": ""
        },
        "darkColorLabel": {
            "type": "string",
            "default": ""
        },
        "darkColorText": {
            "type": "string",
            "default": ""
        },
        "darkColorPlaceholder": {
            "type": "string",
            "default": ""
        },
        "darkColorFieldBg": {
            "type": "string",
            "default": ""
        },
        "darkColorBorder": {
            "type": "string",
            "default": ""
        },
        "darkColorFocus": {
            "type": "string",
            "default": ""
        }
    },
    "supports": {
        "html": false
    },
    "usesContext": [
        "bdfrms/formId",
        "bdfrms/appearanceMode",
        "bdfrms/colorLabel",
        "bdfrms/colorText",
        "bdfrms/colorPlaceholder",
        "bdfrms/colorFieldBg",
        "bdfrms/colorBorder",
        "bdfrms/colorFocus",
        "bdfrms/colorButtonBg",
        "bdfrms/colorButtonText",
        "bdfrms/darkColorLabel",
        "bdfrms/darkColorText",
        "bdfrms/darkColorPlaceholder",
        "bdfrms/darkColorFieldBg",
        "bdfrms/darkColorBorder",
        "bdfrms/darkColorFocus",
        "bdfrms/darkColorButtonBg",
        "bdfrms/darkColorButtonText",
        "bdfrms/colorFormShell",
        "bdfrms/darkColorFormShell"
    ],
    "editorScript": "bdfrms-editor",
    "example": {
        "attributes": {
            "label": "Radio",
            "name": "sb_radio",
            "options": "Wahl A\nWahl B",
            "required": false
        }
